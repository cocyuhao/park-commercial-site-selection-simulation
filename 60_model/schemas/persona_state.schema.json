{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona_state.schema.json",
  "title": "Persona state draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "persona_id",
    "segment_name",
    "state_status",
    "purpose",
    "time_pressure",
    "budget_sensitivity",
    "fatigue_level",
    "companion_context",
    "detour_tolerance",
    "queue_tolerance",
    "risk_notes",
    "evidence_refs",
    "missing_inputs"
  ],
  "properties": {
    "persona_id": {
      "type": "string",
      "minLength": 1
    },
    "segment_name": {
      "type": "string",
      "minLength": 1
    },
    "state_status": {
      "type": "string",
      "enum": [
        "draft",
        "needs_review"
      ]
    },
    "purpose": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "time_pressure": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ]
    },
    "budget_sensitivity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ]
    },
    "fatigue_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ]
    },
    "companion_context": {
      "type": "string",
      "enum": [
        "alone",
        "couple",
        "family",
        "friends",
        "group",
        "unknown"
      ]
    },
    "detour_tolerance": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ]
    },
    "queue_tolerance": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ]
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
