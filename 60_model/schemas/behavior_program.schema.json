{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "behavior_program.schema.json",
  "title": "Behavior program draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "program_id",
    "persona_id",
    "trigger_context",
    "state_preconditions",
    "candidate_actions",
    "transition_notes",
    "source_refs",
    "validation_needed"
  ],
  "properties": {
    "program_id": {
      "type": "string",
      "minLength": 1
    },
    "persona_id": {
      "type": "string",
      "minLength": 1
    },
    "trigger_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "time_window",
        "weather",
        "crowd_level",
        "location_state"
      ],
      "properties": {
        "time_window": {
          "type": "string",
          "minLength": 1
        },
        "weather": {
          "type": "string",
          "enum": [
            "unknown",
            "hot",
            "cold",
            "rain",
            "comfortable"
          ]
        },
        "crowd_level": {
          "type": "string",
          "enum": [
            "unknown",
            "low",
            "medium",
            "high"
          ]
        },
        "location_state": {
          "type": "string",
          "enum": [
            "entry",
            "path",
            "lakefront",
            "activity_node",
            "exit",
            "unknown"
          ]
        }
      }
    },
    "state_preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidate_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action",
          "condition",
          "expected_signal",
          "failure_condition"
        ],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "approach",
              "pass_by",
              "purchase",
              "rest",
              "detour",
              "leave",
              "compare"
            ]
          },
          "condition": {
            "type": "string",
            "minLength": 1
          },
          "expected_signal": {
            "type": "string",
            "minLength": 1
          },
          "failure_condition": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "transition_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_needed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
