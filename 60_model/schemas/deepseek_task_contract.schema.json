{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepseek_task_contract.schema.json",
  "title": "DeepSeek task contract envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "task_type",
    "output_status",
    "source_refs",
    "assumptions",
    "uncertainties",
    "needs_human_review",
    "review_required",
    "items"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "task_type": {
      "type": "string",
      "enum": [
        "source_summary",
        "evidence_candidate",
        "persona_state",
        "behavior_program",
        "choice_probability",
        "simulation_validation_target",
        "node_explanation",
        "report_draft",
        "state_behavior_consistency",
        "micro_reasonableness"
      ]
    },
    "output_status": {
      "type": "string",
      "enum": [
        "draft",
        "needs_review"
      ]
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_file",
          "page_or_slide",
          "quote_or_table_ref"
        ],
        "properties": {
          "source_file": {
            "type": "string",
            "minLength": 1
          },
          "page_or_slide": {
            "type": "string",
            "minLength": 1
          },
          "evidence_id": {
            "type": "string"
          },
          "quote_or_table_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "needs_human_review": {
      "const": true
    },
    "review_required": {
      "const": true,
      "description": "Hard duplicate review flag for downstream systems that should not infer approval from fluent LLM text."
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    }
  }
}
