{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "node_recommendation_explanation.schema.json",
  "title": "Node recommendation explanation draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "node_id",
    "mode",
    "priority_label",
    "why_now",
    "specific_advice",
    "evidence_support",
    "evidence_gaps",
    "review_actions",
    "score_if_any"
  ],
  "properties": {
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "project",
        "node"
      ]
    },
    "priority_label": {
      "type": "string",
      "enum": [
        "优先推进",
        "补资料后判断",
        "仅空间观察",
        "暂缓"
      ]
    },
    "why_now": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "specific_advice": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "evidence_support": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "score_if_any": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "meaning",
        "hidden_by_default"
      ],
      "properties": {
        "value": {
          "type": [
            "number",
            "null"
          ]
        },
        "meaning": {
          "type": "string",
          "minLength": 1
        },
        "hidden_by_default": {
          "const": true
        }
      }
    }
  }
}
